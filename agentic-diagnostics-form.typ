#set page(
  paper: "a4",
  margin: (x: 18mm, y: 17mm),
  footer: context align(right)[#text(size: 8pt, fill: rgb("#777777"))[стр. #counter(page).display()]],
)
#set text(font: "Arial", size: 9.5pt, lang: "ru")
#set par(leading: 0.56em, spacing: 0.58em, justify: false)

#let muted = rgb("#666666")
#let line-gray = rgb("#9a9a9a")
#let table-gray = rgb("#eeeeee")

#let h1(body) = block(spacing: 7pt)[
  #text(size: 18pt, weight: "bold")[#body]
]

#let h2(body) = block(above: 8pt, below: 3pt)[
  #text(size: 13pt, weight: "bold")[#body]
]

#let hint(body) = text(size: 8.7pt, fill: muted)[#body]

#let write-line(label, height: 9mm) = block(height: height)[
  #label
  #v(2.5mm)
  #line(length: 100%, stroke: 0.45pt + line-gray)
]

#let checkbox(body) = block(above: 1.8pt, below: 1.8pt)[
  #box(width: 9pt)[□] #body
]

#let level-row(level, name, desc) = (
  align(center + horizon)[#text(weight: "bold")[#level]],
  [#name],
  [#desc],
)

#h1[Форма диагностики: агентная разработка и автоматизация процессов]

#text(weight: "bold")[Ориентир по времени:] 15-25 минут без поиска артефактов, 30-45 минут с подбором ссылок.

Цель анкеты - быстро понять, как команда уже использует AI в разработке и с чего безопасно начать следующий шаг: обучение, диагностика, пилот, внедрение или пауза.

Уровень внедрения агентной разработки и автоматизации процессов - это рабочая шкала, которая помогает сверить текущее состояние команды. Не пытайтесь выбрать уровень идеально: мы уточним его на разговоре по примерам и артефактам.

Заполняйте коротко. Если не знаете ответ, пишите «не знаем». Это тоже полезный диагностический сигнал.

