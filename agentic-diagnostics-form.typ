#h2[2. Выберите текущий уровень внедрения]
#hint[Выберите ближайшее описание. Если сомневаетесь между двумя уровнями, выберите нижний.]

#v(2pt)
#set table(
  stroke: 0.45pt + rgb("#9b9b9b"),
  inset: (x: 4pt, y: 3.3pt),
  align: (x, y) => if x == 0 { center + horizon } else { left + horizon },
)
#table(
  columns: (17mm, 36mm, 1fr),
  fill: (x, y) => if y == 0 { table-gray } else { none },
  table.header(
    [#text(weight: "bold")[Уровень]],
    [#text(weight: "bold")[Название]],
    [#text(weight: "bold")[Как выглядит на практике]],
  ),
  ..level-row("0", [Отрицание], [AI почти не используется, есть скепсис или запрет без понятного контура эксперимента.]),
  ..level-row("1", [Prompting / личные подсказки], [Отдельные люди используют ChatGPT, Copilot или IDE-подсказки для консультаций и автодополнения.]),
  ..level-row("2", [System / Artifact], [Есть промпты, шаблоны или AI-артефакты «под ключ», но нет общего командного процесса.]),
  ..level-row("3", [Context / общий контекст], [Есть общие правила, спецификации или другой проектный контекст для AI.]),
  ..level-row("4", [Action / действия агента], [Агент действует в рабочем процессе: использует инструменты, меняет код или документы, запускает проверки.]),
  ..level-row("5", [Orchestrator / оркестрация], [Есть несколько агентских процессов, специализированные агенты, реестр процессов, роли и метрики.]),
  ..level-row("6", [Операционная модель], [AI встроен в процессы, интеграции, принятие решений и управление организацией.]),
)

