  ..level-row("5", [Оркестрация процессов], [Есть несколько агентских процессов, специализированные агенты, реестр процессов, роли и метрики.]),
  ..level-row("6", [Операционная модель], [AI встроен в процессы, интеграции, принятие решений и управление организацией.]),
